{
    "$schema": "./config_schema.json",
    "scene_width": 4000,
    "scene_height": 4000,
    "grid_size": 36,
    "antialiasing": true,
    "antialiasing_boost": true,
    "smooth_pixmap": true,

    "viewport_margins": 40,

    "horizontal_node_spacing": 80,
    "vertical_node_spacing": 40,

    "node_font": "Arial",
    "node_font_size": 12,
    "attr_font": "Arial",
    "attr_font_size": 10,
    "mouse_bounding_box": 80,

    "node_width": 200,
    "node_height": 25,
    "node_radius": 10,
    "node_border": 2,
    "node_attr_height": 30,
    "connection_width": 2,
    "connection_grab_radius": 15,

    "alternate_value": 20,
    "bg_color": [40, 40, 40, 255],
    "grid_color": [50, 50, 50, 255],
    "slot_border": [50, 50, 50, 255],
    "non_connectable_color": [100, 100, 100, 255],
    "connection_color": [255, 155, 0, 255],

    "node_default": {
        "bg": [130, 130, 130, 255],
        "border": [50, 50, 50, 255],
        "border_sel": [250, 250, 250, 255],
        "text": [255, 255, 255, 255]
    },

    "attr_default": {
        "bg": [160, 160, 160, 255],
        "text": [220, 220, 220, 255],
        "plug": [255, 155, 0, 255],
        "socket": [255, 155, 0, 255]
    },


    "node_preset_1": {
        "bg": [80, 80, 80, 255],
        "border": [50, 50, 50, 255],
        "border_sel": [170, 80, 80, 255],
        "text": [230, 230, 230, 255]
    },

    "attr_preset_1": {
        "bg": [60, 60, 60, 255],
        "text": [220, 220, 220, 255],
        "plug": [255, 155, 0, 255],
        "socket": [255, 155, 0, 255]
    },

    "attr_preset_2":{
        "bg": [250, 120, 120, 255],
        "text": [220, 220, 220, 255],
        "plug": [255, 155, 0, 255],
        "socket": [255, 155, 0, 255]
    },

    "attr_preset_3":{
        "bg": [160, 160, 160, 255],
        "text": [220, 220, 220, 255],
        "plug": [255, 155, 0, 255],
        "socket": [255, 155, 0, 255]
    },

    "shapes_definitions": {
        "circle": [
            {"ellipse": [[0, 0], [10, 10]]}
        ],
        "rectangle": [
            {"rect": [[0, 0], [10, 10]]}
        ],
        "square": [
            {"rect": [[0, 0], [10, 10]]}
        ],
        "triangle": [
            {"polygon": [[0, 8], [5, 0], [10, 8]]}
        ],
        "diamond": [
            {"polygon": [[5, 0], [10, 5], [5, 10], [0, 5]]}
        ],
        "hexagon": [
            {"polygon": [[2, 0], [8, 0], [10, 4], [8, 8], [2, 8], [0, 4]]}
        ],
        "compound_gear": [
            {"ellipse": [[1, 1], [8, 8]]},
            {"rect": [[0, 4], [10, 2]]},
            {"rect": [[4, 0], [2, 10]]}
        ],
        "star": [
            {"polygon": [[5, 0], [6, 3], [10, 3], [7, 6], [8, 10], [5, 7], [2, 10], [3, 6], [0, 3], [4, 3]]}
        ]
    },

    "slot_shapes": {
        "<class 'str'>": {
            "shape": "circle",
            "color": [255, 128, 0],
            "connection_width": 1,
            "border_width": 2,
            "border_color": [200, 100, 0]
        },
        "<class 'int'>": {
            "shape": "square",
            "color": [128, 255, 255],
            "connection_width": 4,
            "border_width": 1,
            "border_color": [100, 200, 200]
        },
        "<class 'float'>": {
            "shape": "diamond",
            "color": [255, 255, 128],
            "connection_width": 1,
            "border_width": 2,
            "border_color": [200, 200, 100]
        },
        "<class 'bool'>": {
            "shape": "triangle",
            "color": [255, 128, 255],
            "connection_width": 1,
            "border_width": 2,
            "border_color": [200, 100, 200]
        },
        "<class 'dict'>": {
            "shape": "rectangle",
            "color": [0, 128, 255],
            "connection_width": 4,
            "border_width": 1,
            "border_color": [0, 100, 200]
        },
        "<class 'list'>": {
            "shape": "hexagon",
            "color": [128, 255, 128],
            "connection_width": 2,
            "border_width": 3,
            "border_color": [100, 200, 100]
        },
        "<class 'tuple'>": {
            "shape": "diamond",
            "color": [255, 192, 128],
            "connection_width": 2,
            "border_width": 2,
            "border_color": [200, 150, 100]
        },
        "<class 'NoneType'>": {
            "shape": "circle",
            "color": [128, 128, 128],
            "connection_width": 1,
            "border_width": 1,
            "border_color": [100, 100, 100]
        },
        "default": {
            "shape": "circle",
            "color": [255, 155, 0],
            "connection_width": 2,
            "border_width": 2,
            "border_color": [200, 120, 0]
        }
    }
}
